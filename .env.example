# ---------------------------------------------------------------------------
# Azure AI Foundry (Azure OpenAI) configuration
# Copy this file to ".env" and fill in your values.
# ---------------------------------------------------------------------------

# Foundry / Azure OpenAI endpoint, e.g. https://my-foundry-resource.openai.azure.com/
AZURE_OPENAI_ENDPOINT=

# Auth option A: API key (simplest). Leave blank to use Entra ID (DefaultAzureCredential).
AZURE_OPENAI_API_KEY=

# API version for the data-plane REST calls.
AZURE_OPENAI_API_VERSION=2024-08-01-preview

# Deployment name of your speech-to-text model.
# Cost tip: 'whisper' is the cheapest STT option on Foundry.
AZURE_OPENAI_TRANSCRIBE_DEPLOYMENT=whisper

# Deployment name of your chat model used to structure the transcript.
# Cost tip: 'gpt-4o-mini' is ~15-20x cheaper than 'gpt-4o' and works well here.
AZURE_OPENAI_CHAT_DEPLOYMENT=gpt-4o-mini

# Max chunk length (seconds) when splitting long audio. Larger = fewer requests.
# Low-bitrate MP3 keeps each chunk far below the 25MB STT limit, so 900s is safe.
AUDIO_CHUNK_SECONDS=900

# Audio bitrate for the extracted MP3. 32k is ample for speech and minimizes upload size.
AUDIO_BITRATE=32k

# Transcript length (characters) above which structuring switches to cost-bounded
# map-reduce instead of a single LLM call. ~48000 chars ≈ 12k tokens.
STRUCTURE_MAX_CHARS=48000
